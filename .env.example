# ══════════════════════════════════════════════
# HRMS Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control!
# ══════════════════════════════════════════════

# Database
DB_ROOT_PASSWORD=strongRootPassword123!
DB_USERNAME=hrmsuser
DB_PASSWORD=strongDbPassword123!

# JWT — Generate: openssl rand -hex 32
JWT_SECRET=your-256-bit-random-secret-key-minimum-32-characters-change-this
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Redis
REDIS_PASSWORD=strongRedisPassword123!

# Email (Gmail App Password)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourcompany.com
MAIL_PASSWORD=your-gmail-app-password

# App
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Monitoring
GRAFANA_PASSWORD=admin123!

# Production deployment
PROD_HOST=your-server-ip
PROD_USER=deploy
